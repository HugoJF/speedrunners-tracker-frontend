<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
  {{#each this.mapKeys as |map|}}
    <MapSelectionItem
      @map={{map}}
      @selected={{eq @selected map}}
      @onClick={{this.handleMapSelection}}
    >
      {{this.mapName map}}
    </MapSelectionItem>
  {{/each}}
</div>