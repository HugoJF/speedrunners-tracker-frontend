<select
  class="{{join "px-4 py-2 bg-white border rounded" @class}}"
  {{on "change" this.handleOnChange}}
>
  <option>=== Select sprint ===</option>
  {{#each this.savedSprints as |sprint|}}
    <option
      value="{{sprint.id}}"
      selected={{eq @value sprint.id}}
    >
      {{sprint.name}} ({{date-to-human-readable sprint.created_at}})
    </option>
  {{/each}}
</select>