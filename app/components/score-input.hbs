<div class="flex items-center border bg-gray-100 rounded">
  {{#each this.buttons as |score|}}
    <button
      type="button"
      class="{{join
        "px-4 py-2 flex-grow cursor-pointer select-none"
        (if (eq @value score) "text-white bg-blue-500" "hover:bg-gray-200")
      }}"
      {{on "click" (fn this.handleOnClick score)}}
    >
      {{score}}
    </button>
  {{/each}}
</div>