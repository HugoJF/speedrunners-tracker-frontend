<table>
  <thead>
    <tr>
      <td>Date</td>
      <td>de_nerd score</td>
      <td>chase score</td>
      <td>Actions</td>
    </tr>
  </thead>
  <tbody>
    {{#each @dates as |date|}}
    <tr>
      <td>
        <LinkTo class="hover:underline" @route="matches.date.show" @model={{date.date}}>
          {{date.date}}
        </LinkTo>
      </td>
      <td>{{date.denerd_score}}</td>
      <td>{{date.chase_score}}</td>
      <td>
        <Button @type="link" @size="sm" @route="matches.date.show" @model={{date.date}}>
          View
        </Button>
      </td>
    </tr>
    {{/each}}
  </tbody>
</table>